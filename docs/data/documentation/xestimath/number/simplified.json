{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"simplified"},{"kind":"text","text":": "},{"preciseIdentifier":"s:9XestiMath6NumberV","kind":"typeIdentifier","identifier":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number","text":"Number"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this number is already in the simplest internal representation, then"},{"type":"text","text":" "},{"type":"text","text":"this number itself is returned."}]},{"inlineContent":[{"text":"A number may be represented internally by a variety of data structures.","type":"text"},{"text":" ","type":"text"},{"text":"For example, there are different data structures for representing","type":"text"},{"text":" ","type":"text"},{"text":"“large” and “small” exact integers, exact fractions, floating-point","type":"text"},{"text":" ","type":"text"},{"text":"values, and complex numbers. Performing a numeric operation may result","type":"text"},{"text":" ","type":"text"},{"text":"in a number with a representation containing extraneous information.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, the  numbers ","type":"text"},{"code":"5\/4","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"3\/4","type":"codeVoice"},{"text":" are represented internally by","type":"text"},{"text":" ","type":"text"},{"text":"data structures that contain the numerator and denominator of each","type":"text"},{"text":" ","type":"text"},{"text":"number. (Something like, ","type":"text"},{"code":"{ numerator: 5, denominator: 4 }","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"{ numerator: 3, denominator: 4 }","type":"codeVoice"},{"text":", respectively.) Adding those numbers","type":"text"},{"text":" ","type":"text"},{"text":"together results in the number ","type":"text"},{"type":"codeVoice","code":"2"},{"type":"text","text":". However, for efficiency, that result"},{"type":"text","text":" "},{"type":"text","text":"is also represented internally by a data structure that contains "},{"type":"emphasis","inlineContent":[{"text":"both","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"a numerator "},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" a denominator. (Something like, "},{"type":"codeVoice","code":"{ numerator: 2, denominator: 1 }"},{"type":"text","text":".) In this case, the "},{"type":"codeVoice","code":"simplified"},{"type":"text","text":" property would"},{"type":"text","text":" "},{"type":"text","text":"simplify the internal representation to contain "},{"inlineContent":[{"type":"text","text":"only"}],"type":"emphasis"},{"type":"text","text":" the (exact)"},{"type":"text","text":" "},{"type":"text","text":"integer result."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/XestiMath\/documentation\/XestiMath","doc:\/\/XestiMath\/documentation\/XestiMath\/Number"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"XestiMath"}],"title":"simplified","externalID":"s:9XestiMath6NumberV10simplifiedACvp","roleHeading":"Instance Property","symbolKind":"property","extendedModule":"XestiMath","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"simplified"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Number","preciseIdentifier":"s:9XestiMath6NumberV"}],"role":"symbol"},"abstract":[{"type":"text","text":"The simplest internal representation of this number."}],"identifier":{"url":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number\/simplified","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/xestimath\/number\/simplified"]}],"references":{"doc://XestiMath/documentation/XestiMath/Number":{"role":"symbol","abstract":[{"type":"text","text":"A generalized numeric value that supports a “number tower” patterned after"},{"type":"text","text":" "},{"type":"text","text":"that in the Scheme programming language."}],"identifier":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number","kind":"symbol","type":"topic","title":"Number","url":"\/documentation\/xestimath\/number","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"Number","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Number"}]},"doc://XestiMath/documentation/XestiMath/Number/simplified":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"simplified","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Number","kind":"typeIdentifier","preciseIdentifier":"s:9XestiMath6NumberV"}],"title":"simplified","identifier":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number\/simplified","kind":"symbol","role":"symbol","url":"\/documentation\/xestimath\/number\/simplified","abstract":[{"text":"The simplest internal representation of this number.","type":"text"}],"type":"topic"},"doc://XestiMath/documentation/XestiMath":{"type":"topic","identifier":"doc:\/\/XestiMath\/documentation\/XestiMath","role":"collection","url":"\/documentation\/xestimath","abstract":[{"text":"Math tools.","type":"text"}],"title":"XestiMath","kind":"symbol"}}}