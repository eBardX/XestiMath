{"identifier":{"url":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number\/simplified","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"The simplest internal representation of this number."}],"variants":[{"paths":["\/documentation\/xestimath\/number\/simplified"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"externalID":"s:9XestiMath6NumberV10simplifiedACvp","modules":[{"name":"XestiMath"}],"symbolKind":"property","roleHeading":"Instance Property","extendedModule":"XestiMath","title":"simplified","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"simplified"},{"kind":"text","text":": "},{"preciseIdentifier":"s:9XestiMath6NumberV","kind":"typeIdentifier","text":"Number"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/XestiMath\/documentation\/XestiMath","doc:\/\/XestiMath\/documentation\/XestiMath\/Number"]]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"simplified"},{"kind":"text","text":": "},{"preciseIdentifier":"s:9XestiMath6NumberV","identifier":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number","kind":"typeIdentifier","text":"Number"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"If this number is already in the simplest internal representation, then","type":"text"},{"text":" ","type":"text"},{"text":"this number itself is returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A number may be represented internally by a variety of data structures.","type":"text"},{"text":" ","type":"text"},{"text":"For example, there are different data structures for representing","type":"text"},{"text":" ","type":"text"},{"text":"“large” and “small” exact integers, exact fractions, floating-point","type":"text"},{"text":" ","type":"text"},{"text":"values, and complex numbers. Performing a numeric operation may result","type":"text"},{"text":" ","type":"text"},{"text":"in a number with a representation containing extraneous information.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, the  numbers ","type":"text"},{"code":"5\/4","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"3\/4","type":"codeVoice"},{"text":" are represented internally by","type":"text"},{"text":" ","type":"text"},{"text":"data structures that contain the numerator and denominator of each","type":"text"},{"text":" ","type":"text"},{"text":"number. (Something like, ","type":"text"},{"code":"{ numerator: 5, denominator: 4 }","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"{ numerator: 3, denominator: 4 }","type":"codeVoice"},{"text":", respectively.) Adding those numbers","type":"text"},{"text":" ","type":"text"},{"text":"together results in the number ","type":"text"},{"code":"2","type":"codeVoice"},{"text":". However, for efficiency, that result","type":"text"},{"text":" ","type":"text"},{"text":"is also represented internally by a data structure that contains ","type":"text"},{"inlineContent":[{"type":"text","text":"both"}],"type":"emphasis"},{"text":" ","type":"text"},{"text":"a numerator ","type":"text"},{"inlineContent":[{"type":"text","text":"and"}],"type":"emphasis"},{"text":" a denominator. (Something like, ","type":"text"},{"code":"{ numerator: 2, denominator: 1 }","type":"codeVoice"},{"text":".) In this case, the ","type":"text"},{"code":"simplified","type":"codeVoice"},{"text":" property would","type":"text"},{"text":" ","type":"text"},{"text":"simplify the internal representation to contain ","type":"text"},{"inlineContent":[{"type":"text","text":"only"}],"type":"emphasis"},{"text":" the (exact)","type":"text"},{"text":" ","type":"text"},{"text":"integer result.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://XestiMath/documentation/XestiMath/Number":{"abstract":[{"type":"text","text":"A generalized numeric value that supports a “number tower” patterned after"},{"type":"text","text":" "},{"type":"text","text":"that in the Scheme programming language."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Number","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number","url":"\/documentation\/xestimath\/number","navigatorTitle":[{"text":"Number","kind":"identifier"}],"kind":"symbol","role":"symbol","title":"Number"},"doc://XestiMath/documentation/XestiMath/Number/simplified":{"abstract":[{"type":"text","text":"The simplest internal representation of this number."}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"simplified"},{"kind":"text","text":": "},{"preciseIdentifier":"s:9XestiMath6NumberV","kind":"typeIdentifier","text":"Number"}],"type":"topic","identifier":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number\/simplified","url":"\/documentation\/xestimath\/number\/simplified","kind":"symbol","role":"symbol","title":"simplified"},"doc://XestiMath/documentation/XestiMath":{"role":"collection","identifier":"doc:\/\/XestiMath\/documentation\/XestiMath","url":"\/documentation\/xestimath","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Math tools."}],"title":"XestiMath"}}}