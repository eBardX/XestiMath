ion"},{"type":"text","text":" "},{"type":"text","text":"of a non-zero integer and a proper fraction (meaning the numerator"},{"type":"text","text":" "},{"type":"text","text":"is less than the denominator). The integer and fraction parts are"},{"type":"text","text":" "},{"type":"text","text":"separated by a space, unless one of the parts is zero. By default, a"},{"type":"text","text":" "},{"type":"text","text":"zero integer part is suppressed. A zero fraction part is always"},{"type":"text","text":" "},{"type":"text","text":"suppressed."}]},{"syntax":"swift","code":["let formatStyle = Number.FormatStyle(locale: Locale(\"en_US\"))","                        .fractionDisplay(strategy: .mixed())","","formatStyle.format(Number(numerator: -5, denominator: 1))    \/\/ -5","formatStyle.format(Number(numerator: 355, denominator: 113)) \/\/ 3 16\/113","formatStyle.format(Number(numerator: 7, denominator: 8))     \/\/ 7\/8"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To always show the integer part, even when it is zero, pass "},{"type":"codeVoice","code":"true"},{"type":"text","text":" "},{"type":"text","text":"to "},{"isActive":true,"identifier":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number\/FractionDisplayStrategy\/mixed(alwaysShowInteger:)","type":"reference"},{"type":"text","text":"."}]},{"syntax":"swift","code":["let formatStyle = Number.FormatStyle(locale: Locale(\"en_US\"))","                        .fractionDisplay(strategy: .mixed(alwaysShowInteger: true))","","formatStyle.format(Number(numerator: -5, denominator: 1))    \/\/ -5","formatStyle.format(Number(numerator: 355, denominator: 113)) \/\/ 3 16\/113","formatStyle.format(Number(numerator: 7, denominator: 8))     \/\/ 0 7\/8"],"type":"codeListing"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/XestiMath\/documentation\/XestiMath\/Number\/FractionDisplayStrategy\/mixed(alwaysShowInteger:)"},"hierarchy":{"path